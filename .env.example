# Copie para .env (não comitado) e preencha
DB_HOST=localhost
DB_NAME=u788472657_contditeads
DB_USER=u788472657_contditeads
DB_PASS=

APP_ENV=production
APP_BASE_URL=https://cont.diteads.com

# SMTP (Hostinger Email)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=contact@diteads.com
SMTP_PASS=
SMTP_FROM_EMAIL=contact@diteads.com
SMTP_FROM_NAME=Dite Ads

# Push (OneSignal). App ID é público (default no config.php); REST key é SECRETA.
# Enquanto ONESIGNAL_REST_KEY estiver vazia, o envio server-side fica desligado.
ONESIGNAL_APP_ID=73f3f9f0-4e28-4aad-b85f-b8b675af448c
ONESIGNAL_REST_KEY=

# Dite Gateway (pay.diteads.com) — pagamento por cartão confirmado via webhook.
# API_KEY e WEBHOOK_SECRET são SECRETAS. Enquanto vazias, a integração fica desligada.
DITE_BASE_URL=https://pay.diteads.com
DITE_API_KEY=
DITE_WEBHOOK_SECRET=

# Obs.: a chave da API Anthropic (simulador por IA) e as instruções de pagamento
# (Zelle/Wise/QR) ficam na tabela `configuracoes`, editáveis em config_pagamento.php — não aqui.

# Diretório de uploads (relativo ao public_html)
UPLOAD_DIR=uploads
